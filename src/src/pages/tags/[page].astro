---
import Layout from '@/components/layouts/Layout.astro';
import Pagination from '@/components/nav/Pagination.astro';
import { getTags } from '@/services/post/tag';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const tags = await getTags();

  return paginate(tags, { pageSize: 1 });
};

const { page } = Astro.props as { page: Page<string> };
---

<Layout>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h2 class="text-3xl font-bold mb-8">タグ一覧</h2>

    <ul class="flex flex-wrap gap-3">
      {
        page.data.map((tag) => (
          <li>
            <a
              href={`/tag/${tag}/`}
              class="px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-blue-500 hover:text-white transition"
            >
              #{tag}
            </a>
          </li>
        ))
      }
    </ul>

    <Pagination page={page} baseUri="/tags" />
  </div>
</Layout>
